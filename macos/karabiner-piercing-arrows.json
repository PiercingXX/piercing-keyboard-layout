{
  "title": "Piercing AltGr arrows",
  "rules": [
    {
      "description": "Right Option + the keys that type h/j/k/l = ← ↓ ↑ →",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "h", "modifiers": { "mandatory": ["right_option"] } },
          "to": [{ "key_code": "left_arrow" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "period", "modifiers": { "mandatory": ["right_option"] } },
          "to": [{ "key_code": "down_arrow" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "n", "modifiers": { "mandatory": ["right_option"] } },
          "to": [{ "key_code": "up_arrow" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "u", "modifiers": { "mandatory": ["right_option"] } },
          "to": [{ "key_code": "right_arrow" }]
        }
      ]
    }
  ]
}
